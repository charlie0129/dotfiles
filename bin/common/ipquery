#!/bin/bash

set -euo pipefail

for cmd in curl jq; do
    if ! command -v "$cmd" &>/dev/null; then
        echo "error: $cmd is required but not installed" >&2
        exit 1
    fi
done

if [[ "${1:-}" == "-h" ]]; then
    echo "usage: ipquery        query current ip"
    echo "       ipquery <ip>   query the given ip"
    exit 0
fi

# --- Show current public IP when no argument given ---
if [[ $# -eq 0 ]]; then
    ipv4=$(curl -fsSL --max-time 5 "http://v4.ip.zxinc.org/getip" 2>/dev/null || true)
    ipv6=$(curl -fsSL --max-time 5 "http://v6.ip.zxinc.org/getip" 2>/dev/null || true)

    printf "Public IPv4: "
    if [[ -n "$ipv4" ]]; then printf "\033[34m%s\033[0m\n" "$ipv4"; else printf "\033[90munavailable\033[0m\n"; fi

    printf "Public IPv6: "
    if [[ -n "$ipv6" ]]; then printf "\033[34m%s\033[0m\n" "$ipv6"; else printf "\033[90munavailable\033[0m\n"; fi
fi

# --- Query IP geo-location ---
api_url="http://ip.zxinc.org/api.php"

curl_args=(-fsSL -X GET -G "$api_url" --data-urlencode "type=json")
if [[ $# -gt 0 ]]; then
    curl_args+=(--data-urlencode "ip=$1")
fi

ret=$(curl "${curl_args[@]}" | jq -r '.data')
if [[ -z "$ret" || "$ret" == "null" ]]; then
    echo "error: no data returned from API" >&2
    exit 1
fi

query=$(jq -r '.ip.query' <<< "$ret")
location=$(jq -r '.location' <<< "$ret" | sed 's/\t/\n             /g')

printf "Query IP:    \033[32m%s\033[0m\n" "$query"
printf "Location:    \033[32m%s\033[0m\n" "$location"
